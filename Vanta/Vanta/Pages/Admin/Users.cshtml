@page
@using Vanta.Models
@model Vanta.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "User Admin";
}

<section class="space-y-6">
    <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold">User Administration</h1>
            <p class="text-sm text-base-content/60">Create accounts and reset local passwords.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">
            <span>@Model.StatusMessage</span>
        </div>
    }

    <div class="grid gap-6 xl:grid-cols-[420px_minmax(0,1fr)]">
        <section class="rounded-lg border border-base-300 bg-base-100 p-6 shadow-sm">
            <div class="space-y-1">
                <h2 class="text-lg font-semibold">Create Account</h2>
                <p class="text-sm text-base-content/60">New accounts must change password on first sign-in.</p>
            </div>

            <form method="post" asp-page-handler="Create" class="mt-6 space-y-4">
                <div class="form-control">
                    <label class="label" asp-for="CreateInput.LoginId"></label>
                    <input asp-for="CreateInput.LoginId" class="input input-bordered w-full" autocomplete="username" />
                    <span asp-validation-for="CreateInput.LoginId" class="text-sm text-error"></span>
                </div>

                <div class="form-control">
                    <label class="label" asp-for="CreateInput.DisplayName"></label>
                    <input asp-for="CreateInput.DisplayName" class="input input-bordered w-full" autocomplete="name" />
                    <span asp-validation-for="CreateInput.DisplayName" class="text-sm text-error"></span>
                </div>

                <div class="form-control">
                    <label class="label" asp-for="CreateInput.Password"></label>
                    <input asp-for="CreateInput.Password" class="input input-bordered w-full" autocomplete="new-password" />
                    <span asp-validation-for="CreateInput.Password" class="text-sm text-error"></span>
                </div>

                <div class="form-control">
                    <label class="label" asp-for="CreateInput.PasswordConfirmation"></label>
                    <input asp-for="CreateInput.PasswordConfirmation" class="input input-bordered w-full" autocomplete="new-password" />
                    <span asp-validation-for="CreateInput.PasswordConfirmation" class="text-sm text-error"></span>
                </div>

                <label class="label cursor-pointer justify-start gap-3">
                    <input asp-for="CreateInput.IsAdmin" class="checkbox checkbox-sm" />
                    <span class="label-text">Administrator</span>
                </label>

                <div asp-validation-summary="ModelOnly" class="text-sm text-error"></div>

                <button type="submit" class="btn btn-primary w-full">Create User</button>
            </form>
        </section>

        <section class="rounded-lg border border-base-300 bg-base-100 shadow-sm">
            <div class="border-b border-base-300 px-6 py-4">
                <h2 class="text-lg font-semibold">Users</h2>
            </div>

            @if (Model.Users.Count == 0)
            {
                <div class="px-6 py-8 text-sm text-base-content/60">No users found.</div>
            }
            else
            {
                <div class="divide-y divide-base-300">
                    @foreach (User user in Model.Users)
                    {
                        <article class="space-y-4 px-6 py-5">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <div class="space-y-1">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <h3 class="font-semibold">@user.DisplayName</h3>
                                        @if (user.IsAdmin)
                                        {
                                            <span class="badge badge-primary badge-outline">Admin</span>
                                        }
                                        @if (user.MustChangePassword)
                                        {
                                            <span class="badge badge-warning badge-outline">Password Change Required</span>
                                        }
                                        @if (user.IsActive)
                                        {
                                            <span class="badge badge-success badge-outline">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-error badge-outline">Inactive</span>
                                        }
                                    </div>
                                    <div class="text-sm text-base-content/65">
                                        <span class="font-medium">@user.LoginId</span>
                                        <span class="mx-2">|</span>
                                        <span>Created @user.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                        <span class="mx-2">|</span>
                                        <span>Last sign-in @(user.LastSignedInUtc.HasValue ? user.LastSignedInUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-")</span>
                                    </div>
                                </div>
                            </div>

                            <form method="post" asp-page-handler="ResetPassword" class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_auto]">
                                <input type="hidden" name="ResetInput.UserId" value="@user.Id" />

                                <div class="form-control">
                                    <label class="label">
                                        <span class="label-text">New Password</span>
                                    </label>
                                    <input name="ResetInput.NewPassword" type="password" class="input input-bordered w-full" autocomplete="new-password" />
                                </div>

                                <div class="form-control">
                                    <label class="label">
                                        <span class="label-text">Confirm Password</span>
                                    </label>
                                    <input name="ResetInput.NewPasswordConfirmation" type="password" class="input input-bordered w-full" autocomplete="new-password" />
                                </div>

                                <div class="flex items-end">
                                    <button type="submit" class="btn btn-outline w-full lg:w-auto">Reset Password</button>
                                </div>
                            </form>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
