@page
@using Vanta.Models
@using Vanta.ViewModels
@model Vanta.Pages.Projects.EditModel
@{
    ViewData["Title"] = "프로젝트 수정";
}

@functions {
    private string GetModuleSerialNumbersText(ModuleItemViewModel module)
    {
        return string.Join(Environment.NewLine, module.SerialNumbers);
    }
}

<section class="space-y-4">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <h1 class="text-2xl font-black tracking-tight">프로젝트 수정</h1>
            <p class="text-sm text-base-content/60">@Model.Project.Code · @Model.Project.Name</p>
        </div>

        <a class="btn btn-ghost btn-sm" asp-page="/Index" asp-route-code="@Model.Project.Code">목록으로</a>
    </div>

    <form method="post" asp-page-handler="SaveProject" class="rounded-lg border border-base-300 bg-base-100 p-4 shadow-sm">
        <input type="hidden" asp-for="OriginalCode" />
        <div asp-validation-summary="ModelOnly" class="mb-3 text-sm text-error"></div>

        <div class="grid gap-3 lg:grid-cols-3">
            <label class="form-control">
                <span class="label-text font-semibold">프로젝트 코드</span>
                <input asp-for="Code" class="input input-bordered input-sm w-full" />
                <span asp-validation-for="Code" class="text-xs text-error"></span>
            </label>

            <label class="form-control lg:col-span-2">
                <span class="label-text font-semibold">프로젝트명</span>
                <input asp-for="Name" class="input input-bordered input-sm w-full" />
                <span asp-validation-for="Name" class="text-xs text-error"></span>
            </label>

            <label class="form-control">
                <span class="label-text font-semibold">고객사</span>
                <input asp-for="CustomerName" class="input input-bordered input-sm w-full" />
                <span asp-validation-for="CustomerName" class="text-xs text-error"></span>
            </label>

            <label class="form-control">
                <span class="label-text font-semibold">팀</span>
                <input asp-for="TeamName" class="input input-bordered input-sm w-full" />
                <span asp-validation-for="TeamName" class="text-xs text-error"></span>
            </label>

            <label class="form-control">
                <span class="label-text font-semibold">담당자</span>
                <input asp-for="OwnerName" class="input input-bordered input-sm w-full" />
                <span asp-validation-for="OwnerName" class="text-xs text-error"></span>
            </label>

            <label class="form-control">
                <span class="label-text font-semibold">상태</span>
                <select asp-for="StatusName" class="select select-bordered select-sm w-full">
                    <option value="Planning">계획</option>
                    <option value="Active">진행 중</option>
                    <option value="Validation">검증</option>
                    <option value="Completed">완료</option>
                    <option value="Archived">보관</option>
                </select>
                <span asp-validation-for="StatusName" class="text-xs text-error"></span>
            </label>

            <label class="form-control">
                <span class="label-text font-semibold">시작일</span>
                <input asp-for="StartDate" class="input input-bordered input-sm w-full" />
            </label>

            <label class="form-control">
                <span class="label-text font-semibold">종료일</span>
                <input asp-for="EndDate" class="input input-bordered input-sm w-full" />
            </label>
        </div>

        <label class="form-control mt-3">
            <span class="label-text font-semibold">요약</span>
            <textarea asp-for="Summary" class="textarea textarea-bordered min-h-20 w-full"></textarea>
        </label>

        <div class="mt-4 flex justify-end">
            <button type="submit" class="btn btn-primary btn-sm">프로젝트 저장</button>
        </div>
    </form>

    <details class="rounded-lg border border-base-300 bg-base-100">
        <summary class="cursor-pointer list-none px-4 py-3 text-sm font-bold text-base-content">EQP 추가</summary>
        <form method="post" asp-page-handler="CreateEquipment" class="border-t border-base-300 p-4">
            <input type="hidden" name="TargetProjectCode" value="@Model.Project.Code" />

            <div class="grid gap-3 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1fr)_minmax(0,0.9fr)_minmax(0,0.9fr)_auto]">
                <label class="form-control">
                    <span class="label-text font-semibold">EQP 코드</span>
                    <input name="EquipmentCode" class="input input-bordered input-sm w-full" />
                </label>
                <label class="form-control">
                    <span class="label-text font-semibold">EQP 이름</span>
                    <input name="EquipmentName" class="input input-bordered input-sm w-full" />
                </label>
                <label class="form-control">
                    <span class="label-text font-semibold">플랫폼</span>
                    <input name="EquipmentPlatformName" class="input input-bordered input-sm w-full" />
                </label>
                <label class="form-control">
                    <span class="label-text font-semibold">단계</span>
                    <input name="EquipmentStageName" class="input input-bordered input-sm w-full" />
                </label>
                <div class="flex items-end justify-end">
                    <button type="submit" class="btn btn-primary btn-sm">추가</button>
                </div>
            </div>

            <label class="form-control mt-3">
                <span class="label-text font-semibold">설명</span>
                <textarea name="EquipmentDescription" class="textarea textarea-bordered min-h-16 w-full"></textarea>
            </label>
        </form>
    </details>

    <div class="space-y-4">
        @foreach (EquipmentSectionViewModel equipment in Model.Project.Equipments)
        {
            <section class="rounded-lg border border-base-300 bg-base-100 shadow-sm">
                <div class="flex flex-col gap-2 border-b border-base-300 bg-base-200/40 px-4 py-3 lg:flex-row lg:items-center lg:justify-between">
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="rounded-md border border-primary/25 bg-primary/10 px-2.5 py-1 text-xs font-bold text-primary">@equipment.Code</span>
                        <h2 class="text-base font-bold">@equipment.Name</h2>
                    </div>
                    <div class="flex flex-wrap gap-2 text-sm">
                        <span class="rounded-md border border-base-300 bg-base-100 px-3 py-1">플랫폼: @(string.IsNullOrWhiteSpace(equipment.PlatformName) ? "-" : equipment.PlatformName)</span>
                        <span class="rounded-md border border-base-300 bg-base-100 px-3 py-1">단계: @(string.IsNullOrWhiteSpace(equipment.StageName) ? "-" : equipment.StageName)</span>
                    </div>
                </div>

                <details class="border-b border-base-300">
                    <summary class="cursor-pointer list-none px-4 py-3 text-sm font-bold">EQP 수정</summary>
                    <form method="post" asp-page-handler="UpdateEquipment" class="border-t border-base-300 p-4">
                        <input type="hidden" name="TargetProjectCode" value="@Model.Project.Code" />
                        <input type="hidden" name="EquipmentOriginalCode" value="@equipment.Code" />

                        <div class="grid gap-3 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1fr)_minmax(0,0.9fr)_minmax(0,0.9fr)_auto]">
                            <label class="form-control">
                                <span class="label-text font-semibold">EQP 코드</span>
                                <input name="EquipmentCode" value="@equipment.Code" class="input input-bordered input-sm w-full" />
                            </label>
                            <label class="form-control">
                                <span class="label-text font-semibold">EQP 이름</span>
                                <input name="EquipmentName" value="@equipment.Name" class="input input-bordered input-sm w-full" />
                            </label>
                            <label class="form-control">
                                <span class="label-text font-semibold">플랫폼</span>
                                <input name="EquipmentPlatformName" value="@equipment.PlatformName" class="input input-bordered input-sm w-full" />
                            </label>
                            <label class="form-control">
                                <span class="label-text font-semibold">단계</span>
                                <input name="EquipmentStageName" value="@equipment.StageName" class="input input-bordered input-sm w-full" />
                            </label>
                            <div class="flex items-end justify-end">
                                <button type="submit" class="btn btn-primary btn-sm">저장</button>
                            </div>
                        </div>

                        <label class="form-control mt-3">
                            <span class="label-text font-semibold">설명</span>
                            <textarea name="EquipmentDescription" class="textarea textarea-bordered min-h-16 w-full">@equipment.Description</textarea>
                        </label>
                    </form>

                    <form method="post" asp-page-handler="DeleteEquipment" class="border-t border-base-300 p-4">
                        <input type="hidden" name="TargetProjectCode" value="@Model.Project.Code" />
                        <input type="hidden" name="EquipmentOriginalCode" value="@equipment.Code" />
                        <button type="submit" class="btn btn-error btn-outline btn-sm">EQP 삭제</button>
                    </form>
                </details>

                <details class="border-b border-base-300">
                    <summary class="cursor-pointer list-none px-4 py-3 text-sm font-bold">Module 추가</summary>
                    <form method="post" asp-page-handler="CreateModule" class="border-t border-base-300 p-4">
                        <input type="hidden" name="TargetProjectCode" value="@Model.Project.Code" />
                        <input type="hidden" name="ModuleEquipmentCode" value="@equipment.Code" />
                        @await Html.PartialAsync("_ModuleEditorFields", new Vanta.Pages.Projects.ModuleEditorFieldsViewModel())
                        <div class="mt-4 flex justify-end">
                            <button type="submit" class="btn btn-primary btn-sm">Module 추가</button>
                        </div>
                    </form>
                </details>

                <div class="divide-y divide-base-300">
                    @if (equipment.Modules.Count == 0)
                    {
                        <div class="px-4 py-6 text-center text-sm text-base-content/60">등록된 Module이 없습니다.</div>
                    }
                    else
                    {
                        @foreach (ModuleItemViewModel module in equipment.Modules)
                        {
                            <details class="px-4 py-3">
                                <summary class="cursor-pointer list-none text-sm font-bold">
                                    @module.TypeName · @module.Name
                                </summary>

                                <form method="post" asp-page-handler="UpdateModule" class="mt-3 rounded-lg border border-base-300 p-3">
                                    <input type="hidden" name="TargetProjectCode" value="@Model.Project.Code" />
                                    <input type="hidden" name="ModuleEquipmentCode" value="@equipment.Code" />
                                    <input type="hidden" name="ModuleOriginalCode" value="@module.Code" />
                                    @await Html.PartialAsync("_ModuleEditorFields", new Vanta.Pages.Projects.ModuleEditorFieldsViewModel(module, GetModuleSerialNumbersText(module)))
                                    <div class="mt-4 flex justify-end">
                                        <button type="submit" class="btn btn-primary btn-sm">Module 저장</button>
                                    </div>
                                </form>

                                <form method="post" asp-page-handler="DeleteModule" class="mt-2">
                                    <input type="hidden" name="TargetProjectCode" value="@Model.Project.Code" />
                                    <input type="hidden" name="ModuleEquipmentCode" value="@equipment.Code" />
                                    <input type="hidden" name="ModuleOriginalCode" value="@module.Code" />
                                    <button type="submit" class="btn btn-error btn-outline btn-sm">Module 삭제</button>
                                </form>
                            </details>
                        }
                    }
                </div>
            </section>
        }
    </div>
</section>
