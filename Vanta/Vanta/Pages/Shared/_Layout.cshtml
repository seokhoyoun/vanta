<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vanta</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/vanta-daisy.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Vanta.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-base-200 text-base-content">
    <header class="sticky top-0 z-30 border-b border-base-300 bg-base-100/92 backdrop-blur">
        <div class="navbar mx-auto w-full max-w-[1800px] px-4 lg:px-6">
            <div class="flex-1">
                <a class="text-xl font-black tracking-[0.22em] text-primary" asp-area="" asp-page="/Index">VANTA</a>
            </div>
            <div class="flex items-center gap-3">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-sm btn-outline" asp-page="/Admin/Users">Users</a>
                    }
                    <span class="text-sm text-base-content/70">@User.Identity!.Name</span>
                    <form method="post" asp-page="/Account/Logout">
                        <button type="submit" class="btn btn-sm btn-outline">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-sm btn-outline" asp-page="/Account/Login">Login</a>
                }
            </div>
        </div>
    </header>

    <main class="mx-auto w-full max-w-[1800px] px-4 py-6 lg:px-6 lg:py-8">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
