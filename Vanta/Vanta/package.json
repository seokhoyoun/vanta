{
  "name": "vanta",
  "private": true,
  "version": "1.0.0",
  "description": "Vanta dashboard pilot styles with Tailwind CSS and daisyUI",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./app.css -o ./wwwroot/css/vanta-daisy.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./app.css -o ./wwwroot/css/vanta-daisy.css --watch"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2"
  }
}
